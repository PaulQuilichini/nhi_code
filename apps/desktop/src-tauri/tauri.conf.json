{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "NHI Code",
  "version": "0.1.0",
  "identifier": "com.nhicode.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm build:server && pnpm vite",
    "beforeBuildCommand": "pnpm build:web && pnpm build:server"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "NHI Code",
        "width": 1280,
        "height": 860,
        "minWidth": 900,
        "minHeight": 600,
        "center": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self' asset:",
        "script-src": "'self' 'unsafe-inline' 'unsafe-eval'",
        "style-src": "'unsafe-inline' 'self' https://fonts.googleapis.com",
        "font-src": "'self' https://fonts.gstatic.com",
        "img-src": "'self' asset: http://asset.localhost https://asset.localhost blob: data:",
        "connect-src": "ipc: http://ipc.localhost http://127.0.0.1:3847 http://localhost:3847 ws://127.0.0.1:3847 ws://localhost:3847 http://localhost:5173 ws://localhost:5173 http://127.0.0.1:5173 ws://127.0.0.1:5173"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../dist-server/bundle.cjs": "server/bundle.cjs"
    }
  }
}
