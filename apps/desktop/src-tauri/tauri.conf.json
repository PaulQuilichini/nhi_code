{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "NHI Code",
  "version": "0.1.0",
  "identifier": "com.nhicode.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm build:server && pnpm vite",
    "beforeBuildCommand": "pnpm build:web && pnpm build:server"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "NHI Code",
        "width": 1280,
        "height": 860,
        "minWidth": 900,
        "minHeight": 600,
        "center": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:3847 http://localhost:3847 ws://127.0.0.1:3847 ws://localhost:3847; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../dist-server/bundle.cjs": "server/bundle.cjs"
    }
  }
}
