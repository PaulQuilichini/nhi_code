{
  "name": "nhicode",
  "private": true,
  "version": "0.1.0",
  "description": "NHI Code — Non-Human Intelligence coding agent for DeepSeek, Kimi, Qwen and other OpenAI-compatible models",
  "scripts": {
    "build:packages": "node scripts/build-packages-direct.mjs",
    "verify": "pnpm build:packages",
    "dev": "pnpm build:packages && pnpm --filter @nhicode/desktop dev",
    "build": "pnpm build:packages && pnpm --filter @nhicode/desktop build",
    "typecheck": "pnpm -r typecheck",
    "benchmark:context": "node scripts/context-benchmark.mjs",
    "test:carefulness": "node scripts/carefulness-self-test.mjs",
    "start": "pnpm --filter @nhicode/desktop start"
  },
  "engines": {
    "node": ">=20"
  }
}
